{
  "name": "@miracle3010/ai-orchestrator",
  "version": "0.1.1",
  "description": "Plan-code-judge AI orchestration for Pi and Cursor.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/src/index.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "test": "vitest run --exclude=dist/**",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "ai-orchestrator-mcp": "bin/ai-orchestrator-mcp.js",
    "ai-orchestrator": "bin/ai-orchestrator.js"
  },
  "files": [
    "dist",
    "bin",
    "cursor",
    "skills",
    "extensions",
    "mcp",
    "src",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/graph-architecture.md",
    "docs/setup.md",
    "docs/user-guide.md",
    "docs/images/ai-orchestrator-workflow.svg",
    "docs/images/ai-orchestrator-workflow.png"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nguyen-ta-cuong/ai-orchestrator.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "mcp",
    "cursor"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "image": "https://cdn.jsdelivr.net/npm/@miracle3010/ai-orchestrator/docs/images/ai-orchestrator-workflow.png"
  },
  "author": "Cuong Nguyen",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nguyen-ta-cuong/ai-orchestrator/issues"
  },
  "homepage": "https://github.com/nguyen-ta-cuong/ai-orchestrator#readme",
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25 || ^4.0"
  },
  "overrides": {
    "@hono/node-server": "2.0.11",
    "fast-uri": "3.1.4"
  }
}
